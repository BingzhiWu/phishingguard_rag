# PhishingGuard-RAG Environment Configuration
# Copy this file to .env and fill in your values

# Ollama endpoint (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model name (must be pulled via: ollama pull mistral)
LLM_MODEL=mistral

# Optional: OpenAI API key (only needed if using OpenAI instead of Ollama)
# OPENAI_API_KEY=sk-...
